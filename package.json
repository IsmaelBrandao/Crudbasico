{
  "name": "next-comercial",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter next-comercial-frontend dev",
    "dev:frontend": "pnpm --filter next-comercial-frontend dev",
    "dev:backend": "pnpm --filter next-comercial-backend dev",
    "build": "pnpm --filter next-comercial-frontend build",
    "start": "pnpm --filter next-comercial-frontend start",
    "start:backend": "pnpm --filter next-comercial-backend start",
    "db:migrate": "pnpm --filter next-comercial-backend db:migrate",
    "db:migrate:undo": "pnpm --filter next-comercial-backend db:migrate:undo",
    "preview": "pnpm --filter next-comercial-frontend preview",
    "lint": "pnpm --filter next-comercial-frontend lint",
    "typecheck": "pnpm --filter next-comercial-frontend typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm build"
  }
}
